# Database
DATABASE_URL="postgresql://user:password@localhost:5432/depotai"

# AI (required for /v1/chat/prompt)
AI_GATEWAY_API_KEY="your-gateway-api-key"
# Model identifier (optional; default: openai/gpt-4o-mini)
AI_MODEL="openai/gpt-4o-mini"
# AI Gateway connection timeout in ms (default 30000). Increase if you hit connect timeout errors.
# AI_GATEWAY_CONNECT_TIMEOUT_MS=30000
# Retries for gateway stream fallback on timeout-like failures (default 2).
# AI_GATEWAY_STREAM_RETRIES=2

# Claude API integration (optional)
# CLAUDE_API_KEY="your-anthropic-api-key"
# Model ID (optional; default: claude-sonnet-4-6). Older IDs like claude-3-5-sonnet-latest return 404.
# CLAUDE_MODEL="claude-sonnet-4-6"
#
# Anthropic server tools (enable “Web search” + “Web fetch” for your workspace in https://console.anthropic.com — billing applies)
# CLAUDE_WEB_SEARCH_ENABLED=true
# CLAUDE_WEB_FETCH_ENABLED=true
# CLAUDE_WEB_SEARCH_MAX_USES=10
# CLAUDE_WEB_FETCH_MAX_USES=5
# Optional comma-separated hostnames (no scheme), e.g. retailer-focused product lookup:
# CLAUDE_WEB_ALLOWED_DOMAINS=amazon.com,bestbuy.com,keepa.com,cdw.com
#
# Stream token deltas from Claude (recommended; shows live typing + real web tool phases). Set false for one-shot mode.
# CLAUDE_STREAMING_ENABLED=true
# Validate image URLs returned by Claude and auto-retry with new sources when broken (recommended true).
# CLAUDE_VALIDATE_IMAGE_URLS=true
#
# Claude database tools (optional): model can read/write allowlisted tables; writes require the user to type the password in chat.
# CLAUDE_DB_TOOLS_ENABLED=true
# CLAUDE_DB_TABLE_ALLOWLIST=products,product_variants,brands,categories
# If unset, server falls back to a default password—set explicitly in production, e.g. CLAUDE_DB_WRITE_PASSWORD="Zokulabs123!"

# Valyu web search (optional; get free key at https://platform.valyu.ai)
# VALYU_API_KEY="your-valyu-api-key"

# Chat — how many prior user/assistant messages to include (default 20, max 200). Helps the model follow corrections and context in-thread.
# CHAT_HISTORY_LIMIT=40

# Server
PORT=3000
# Optional; if set, all routes require x-api-key header matching this value
# API_KEY="your-secret-api-key"

# When API_KEY is not set: only requests whose Host matches a domain listed in DOMAIN_CHAT are limited per day per IP; all other domains are unlimited. DOMAIN_CHAT can be one or more hostnames, comma-separated (e.g. chat.example.com or chat.a.com,chat.b.com). Limit per listed domain: default 5, or PROMPTS_PER_DAY_CHAT. Omit DOMAIN_CHAT for unlimited prompts everywhere.
# DOMAIN_CHAT="chat.example.com"
# DOMAIN_CHAT="chat.a.com,chat.b.com"
# PROMPTS_PER_DAY_CHAT=5

# Swagger / docs (optional). PLATFORM_URL also controls branding: copyright is shown only when request host matches this URL's host or is a subdomain.
PLATFORM_NAME="DepotAi"
PLATFORM_URL="http://localhost:3000"
DEVELOPMENT_URL="localhost:3000"
PRODUCTION_URL="your-production-host.com"

# CORS — origins allowed in addition to all localhost ports (http/https)
# Comma-separated list of fully-qualified origins (no trailing slash)
# CORS_ORIGINS="https://your-app.com,https://another-domain.com"

# Branding shown in the demo UI header ("by X") and footer; always shown on localhost, and on PLATFORM_URL or its subdomains; otherwise hidden (optional)
# AUTHOR_NAME="your-name"
# AUTHOR_URL="https://your-website.com"

# Slack (optional; required for Slack bot integration)
# Bot token from your Slack app's OAuth & Permissions page (starts with xoxb-)
# SLACK_BOT_TOKEN="xoxb-your-bot-token"
# Signing secret from your Slack app's Basic Information page — used to verify requests from Slack
# SLACK_SIGNING_SECRET="your-signing-secret"

# Enrichment — background jobs are OFF by default (chat-driven / explicit API only)
# Periodic scan → enqueue jobs (set true only if you want autonomous scheduling)
# ENRICHMENT_SCHEDULER_ENABLED=false
# Redis queue worker that processes enrichment jobs (set true only with Redis + jobs)
# ENRICHMENT_WORKER_ENABLED=false
# REDIS_URL="redis://127.0.0.1:6379"
# Optional tuning: ENRICHMENT_INTERVAL_MS, ENRICHMENT_SCAN_LIMIT, ENRICHMENT_WORKER_REDIS_BACKOFF_MS

# WhatsApp Cloud API (optional; required for WhatsApp bot integration)
# WHATSAPP_CLOUD_API_VERSION="v17.0"
# WHATSAPP_CLOUD_API_PHONE_NUMBER_ID="your-phone-number-id"
# WHATSAPP_CLOUD_API_ACCESS_TOKEN="your-access-token"
# Token you set in the Meta webhook config to verify the subscription challenge
# WHATSAPP_CLOUD_API_WEBHOOK_VERIFICATION_TOKEN="your-webhook-verify-token"
